{
    "name": "ApiValueReader",
    "description": "Verilen URL'den JSON ceker, alan degerlerini script'te kullanilabilir deger olarak dondurur",
    "newInstancePrefix": "ApiValue",
    "eula": "",
    "vendor": "Custom",
    "license": "",
    "id": "com.custom.apivalue",
    "version": "1.0.3",
    "icon": "",
    "webcomponents": [
        {
            "kind": "main",
            "tag": "custom-api-value",
            "url": "https://bizimniyan.github.io/JCNV/main.js?v=103",
            "integrity": "",
            "ignoreIntegrity": true
        },
        {
            "kind": "builder",
            "tag": "custom-api-value-builder",
            "url": "https://bizimniyan.github.io/JCNV/builder.js?v=103",
            "integrity": "",
            "ignoreIntegrity": true
        }
    ],
    "properties": {
        "url": { "type": "string", "default": "" }
    },
    "methods": {
        "load": {
            "description": "URL'den JSON ceker (GET), satirlari hafizaya alir",
            "parameters": [ { "name": "url", "type": "string", "description": "GET URL" } ],
            "returnType": "boolean",
            "body": "return this.load(url);"
        },
        "getCount": {
            "description": "Satir sayisi",
            "parameters": [],
            "returnType": "integer",
            "body": "return this.getCount();"
        },
        "getHttpStatus": {
            "description": "Son cagrinin HTTP kodu",
            "parameters": [],
            "returnType": "integer",
            "body": "return this.getHttpStatus();"
        },
        "getRaw": {
            "description": "Ham yanit metni",
            "parameters": [],
            "returnType": "string",
            "body": "return this.getRaw();"
        },
        "getValue": {
            "description": "Tek deger: field (a.b.c olabilir), index (0 tabanli)",
            "parameters": [
                { "name": "field", "type": "string" },
                { "name": "index", "type": "integer" }
            ],
            "returnType": "string",
            "body": "return this.getValue(field,index);"
        },
        "getValues": {
            "description": "Bir alanin tum degerleri",
            "parameters": [ { "name": "field", "type": "string" } ],
            "returnType": "string[]",
            "body": "return this.getValues(field);"
        },
        "getValuesCsv": {
            "description": "Bir alanin tum degerleri (virgullu tek string)",
            "parameters": [ { "name": "field", "type": "string" } ],
            "returnType": "string",
            "body": "return this.getValuesCsv(field);"
        },
        "getValuesFiltered": {
            "description": "Istenen sayida kosul: filters = \"f1=v1;f2=v2;...\" (bos = filtre yok)",
            "parameters": [
                { "name": "field", "type": "string" },
                { "name": "filters", "type": "string" }
            ],
            "returnType": "string[]",
            "body": "return this.getValuesFiltered(field,filters);"
        },
        "getValuesFilteredCsv": {
            "description": "getValuesFiltered sonucu virgullu tek string",
            "parameters": [
                { "name": "field", "type": "string" },
                { "name": "filters", "type": "string" }
            ],
            "returnType": "string",
            "body": "return this.getValuesFilteredCsv(field,filters);"
        },
        "getValueOfMaxFiltered": {
            "description": "Kosullara uyan satirlar icinde orderField'i en buyuk satirin returnField degeri; filters = \"f1=v1;f2=v2;...\"",
            "parameters": [
                { "name": "returnField", "type": "string" },
                { "name": "orderField", "type": "string" },
                { "name": "filters", "type": "string" }
            ],
            "returnType": "string",
            "body": "return this.getValueOfMaxFiltered(returnField,orderField,filters);"
        }
    },
    "events": {}
}
