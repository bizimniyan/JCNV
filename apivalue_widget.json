{
    "name": "ApiValueReader",
    "description": "Verilen URL'den JSON ceker, alan degerlerini script'te kullanilabilir deger olarak dondurur",
    "newInstancePrefix": "ApiValue",
    "eula": "",
    "vendor": "Custom",
    "license": "",
    "id": "com.custom.apivalue",
    "version": "1.0.7",
    "icon": "",
    "webcomponents": [
        {
            "kind": "main",
            "tag": "custom-api-value",
            "url": "https://bizimniyan.github.io/JCNV/main.js?v=107",
            "integrity": "",
            "ignoreIntegrity": true
        },
        {
            "kind": "builder",
            "tag": "custom-api-value-builder",
            "url": "https://bizimniyan.github.io/JCNV/builder.js?v=107",
            "integrity": "",
            "ignoreIntegrity": true
        }
    ],
    "properties": {
        "url": {
            "type": "string",
            "default": ""
        }
    },
    "methods": {
        "post": {
            "description": "URL'e JSON POST eder (CSRF otomatik), yaniti hafizaya alir",
            "parameters": [
                {
                    "name": "url",
                    "type": "string",
                    "description": "POST URL"
                },
                {
                    "name": "body",
                    "type": "string",
                    "description": "JSON govde (string)"
                }
            ],
            "returnType": "boolean"
        },
        "load": {
            "description": "URL'den JSON ceker (GET), satirlari hafizaya alir",
            "parameters": [
                {
                    "name": "url",
                    "type": "string",
                    "description": "GET URL"
                }
            ],
            "returnType": "boolean"
        },
        "getCount": {
            "description": "Satir sayisi",
            "parameters": [],
            "returnType": "integer"
        },
        "getHttpStatus": {
            "description": "Son cagrinin HTTP kodu",
            "parameters": [],
            "returnType": "integer"
        },
        "getRaw": {
            "description": "Ham yanit metni",
            "parameters": [],
            "returnType": "string"
        },
        "getValue": {
            "description": "Tek deger: field (a.b.c olabilir), index (0 tabanli)",
            "parameters": [
                {
                    "name": "field",
                    "type": "string"
                },
                {
                    "name": "index",
                    "type": "integer"
                }
            ],
            "returnType": "string"
        },
        "getValues": {
            "description": "Bir alanin tum degerleri",
            "parameters": [
                {
                    "name": "field",
                    "type": "string"
                }
            ],
            "returnType": "string[]"
        },
        "getValuesCsv": {
            "description": "Bir alanin tum degerleri (virgullu tek string)",
            "parameters": [
                {
                    "name": "field",
                    "type": "string"
                }
            ],
            "returnType": "string"
        },
        "getValuesFiltered": {
            "description": "Istenen sayida kosul: filters = \"f1=v1;f2=v2;...\" (bos = filtre yok)",
            "parameters": [
                {
                    "name": "field",
                    "type": "string"
                },
                {
                    "name": "filters",
                    "type": "string"
                }
            ],
            "returnType": "string[]"
        },
        "getValuesFilteredCsv": {
            "description": "getValuesFiltered sonucu virgullu tek string",
            "parameters": [
                {
                    "name": "field",
                    "type": "string"
                },
                {
                    "name": "filters",
                    "type": "string"
                }
            ],
            "returnType": "string"
        },
        "getValueOfMaxFiltered": {
            "description": "Kosullara uyan satirlar icinde orderField'i en buyuk satirin returnField degeri; filters = \"f1=v1;f2=v2;...\"",
            "parameters": [
                {
                    "name": "returnField",
                    "type": "string"
                },
                {
                    "name": "orderField",
                    "type": "string"
                },
                {
                    "name": "filters",
                    "type": "string"
                }
            ],
            "returnType": "string"
        }
    },
    "events": {}
}
