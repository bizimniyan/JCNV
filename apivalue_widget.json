{
    "name": "ApiValueReader",
    "description": "Verilen URL'den JSON ceker, alan degerlerini script'te kullanilabilir deger olarak dondurur",
    "newInstancePrefix": "ApiValue",
    "eula": "",
    "vendor": "Custom",
    "license": "",
    "id": "com.custom.apivalue",
    "version": "1.0.1",
    "icon": "",
    "webcomponents": [
        {
            "kind": "main",
            "tag": "custom-api-value",
            "url": "https://bizimniyan.github.io/JCNV/main.js?v=101",
            "integrity": "",
            "ignoreIntegrity": true
        },
        {
            "kind": "builder",
            "tag": "custom-api-value-builder",
            "url": "https://bizimniyan.github.io/JCNV/builder.js?v=101",
            "integrity": "",
            "ignoreIntegrity": true
        }
    ],
    "properties": {
        "url": { "type": "string", "default": "" }
    },
    "methods": {
        "load": {
            "description": "URL'den JSON ceker (GET), satirlari hafizaya alir",
            "parameters": [ { "name": "url", "type": "string", "description": "GET URL" } ],
            "returnType": "boolean",
            "body": "return this.load(url);"
        },
        "getCount": {
            "description": "Satir sayisi",
            "parameters": [],
            "returnType": "integer",
            "body": "return this.getCount();"
        },
        "getHttpStatus": {
            "description": "Son cagrinin HTTP kodu",
            "parameters": [],
            "returnType": "integer",
            "body": "return this.getHttpStatus();"
        },
        "getRaw": {
            "description": "Ham yanit metni",
            "parameters": [],
            "returnType": "string",
            "body": "return this.getRaw();"
        },
        "getValue": {
            "description": "Tek deger: field (a.b.c olabilir), index (0 tabanli)",
            "parameters": [
                { "name": "field", "type": "string" },
                { "name": "index", "type": "integer" }
            ],
            "returnType": "string",
            "body": "return this.getValue(field,index);"
        },
        "getValues": {
            "description": "Bir alanin tum degerleri",
            "parameters": [ { "name": "field", "type": "string" } ],
            "returnType": "string[]",
            "body": "return this.getValues(field);"
        },
        "getValuesCsv": {
            "description": "Bir alanin tum degerleri (virgullu tek string)",
            "parameters": [ { "name": "field", "type": "string" } ],
            "returnType": "string",
            "body": "return this.getValuesCsv(field);"
        },
        "getValuesWhere": {
            "description": "filterField==filterValue olan satirlardan field degerleri",
            "parameters": [
                { "name": "field", "type": "string" },
                { "name": "filterField", "type": "string" },
                { "name": "filterValue", "type": "string" }
            ],
            "returnType": "string[]",
            "body": "return this.getValuesWhere(field,filterField,filterValue);"
        },
        "getValuesWhereCsv": {
            "description": "getValuesWhere sonucu virgullu tek string",
            "parameters": [
                { "name": "field", "type": "string" },
                { "name": "filterField", "type": "string" },
                { "name": "filterValue", "type": "string" }
            ],
            "returnType": "string",
            "body": "return this.getValuesWhereCsv(field,filterField,filterValue);"
        },
        "getValueOfMax": {
            "description": "orderField'i en buyuk satirin returnField degeri",
            "parameters": [
                { "name": "returnField", "type": "string" },
                { "name": "orderField", "type": "string" }
            ],
            "returnType": "string",
            "body": "return this.getValueOfMax(returnField,orderField);"
        },
        "getValueOfMaxWhere": {
            "description": "Filtreli satirlar icinde orderField'i en buyuk satirin returnField degeri",
            "parameters": [
                { "name": "returnField", "type": "string" },
                { "name": "orderField", "type": "string" },
                { "name": "filterField", "type": "string" },
                { "name": "filterValue", "type": "string" }
            ],
            "returnType": "string",
            "body": "return this.getValueOfMaxWhere(returnField,orderField,filterField,filterValue);"
        },
        "getValuesWhere2": {
            "description": "Iki filtre: f1==v1 VE f2==v2 olan satirlardan field degerleri",
            "parameters": [
                { "name": "field", "type": "string" },
                { "name": "f1", "type": "string" },
                { "name": "v1", "type": "string" },
                { "name": "f2", "type": "string" },
                { "name": "v2", "type": "string" }
            ],
            "returnType": "string[]",
            "body": "return this.getValuesWhere2(field,f1,v1,f2,v2);"
        },
        "getValueOfMaxWhere2": {
            "description": "Iki filtreli satirlar icinde orderField'i en buyuk satirin returnField degeri",
            "parameters": [
                { "name": "returnField", "type": "string" },
                { "name": "orderField", "type": "string" },
                { "name": "f1", "type": "string" },
                { "name": "v1", "type": "string" },
                { "name": "f2", "type": "string" },
                { "name": "v2", "type": "string" }
            ],
            "returnType": "string",
            "body": "return this.getValueOfMaxWhere2(returnField,orderField,f1,v1,f2,v2);"
        }
    },
    "events": {}
}
